# ─────────────────────────────────────────────────
# TalkItLn — Environment Variables
# Copy this to .env and fill in real values.
# ─────────────────────────────────────────────────

# === Django Core ===
DEBUG=False
SECRET_KEY=change-me-to-a-real-50-char-random-string

# Comma-separated. Include your domain and any IPs that hit Django directly.
ALLOWED_HOSTS=talkitln.duckdns.org,localhost,127.0.0.1

# === Database (PostgreSQL) ===
DB_NAME=talkit_db
DB_USER=sudeis
DB_PASSWORD=change-me-to-a-strong-password
# DATABASE_URL is built automatically in docker-compose.yaml from the above.

# === CORS & CSRF ===
# Comma-separated origins (with scheme). Must match how browsers reach the site.
CORS_ALLOWED_ORIGINS=https://talkitln.duckdns.org
CSRF_TRUSTED_ORIGINS=https://talkitln.duckdns.org

# === Frontend (Next.js) ===
# The public URL the *browser* uses to reach the Django API.
# For VPS with Nginx reverse proxy, this is the same domain (Nginx routes /api/* to Django).
NEXT_PUBLIC_API_URL=https://talkitln.duckdns.org
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id

# === OAuth (server-side) ===
GOOGLE_CLIENT_ID=your-google-client-id
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# === AI / Gemini ===
GOOGLE_API_KEY=your-gemini-api-key

# === Cloudinary (file uploads) ===
# Either provide CLOUDINARY_URL or the three individual keys:
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# === Email (SMTP) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ─────────────────────────────────────────────────
# The following are set automatically by docker-compose.yaml.
# You do NOT need to set them in .env:
#   DATABASE_URL, CELERY_BROKER_URL, CELERY_RESULT_BACKEND,
#   REDIS_CACHE_URL, CHANNEL_REDIS_URL
# ─────────────────────────────────────────────────
